{
  "name": "PortableUi",
  "packageManager": "yarn@4.9.2",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "dist/*"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "yarn build",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "build:examples": "webpack --config webpack.examples.config.js",
    "build:examples:w": "webpack -w --config webpack.examples.config.js",
    "build:examples:prod": "webpack --mode production --config webpack.examples.config.js",
    "dev:examples": "webpack serve --config webpack.examples.config.js"
  },
  "dependencies": {
    "alien-signals": "^3.2.1",
    "lodash": "^4.18.1",
    "moment": "^2.30.1",
    "typescript": "^6.0.3",
    "zone.js": "^0.16.2"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4",
    "css-loader": "^7.1.2",
    "html-webpack-plugin": "^5.6.3",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "sass": "^1.100.0",
    "sass-loader": "^17.0.0",
    "style-loader": "^4.0.0",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.5.4",
    "webpack": "^5.102.1",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.2"
  }
}
